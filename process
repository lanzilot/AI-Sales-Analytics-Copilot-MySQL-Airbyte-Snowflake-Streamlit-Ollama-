CREATE DATABASE IF NOT EXISTS SALES_DW;
CREATE SCHEMA IF NOT EXISTS SALES_DW.BRONZE;
CREATE SCHEMA IF NOT EXISTS SALES_DW.SILVER;
CREATE SCHEMA IF NOT EXISTS SALES_DW.GOLD;
CREATE SCHEMA IF NOT EXISTS SALES_DW.GOVERNANCE;

CREATE OR REPLACE TABLE SALES_DW.SILVER.CUSTOMER AS
SELECT
    ID                  AS CUSTOMER_ID,
    TRIM(CUSTCODE)      AS CUSTOMER_CODE,
    INITCAP(CUSTNAME)   AS CUSTOMER_NAME,
    ADDRESS,
    CONTNO              AS CONTACT_NUMBER,
    TERMS,
    CONTPER             AS CONTACT_PERSON,
    CREDITLIMIT         AS CREDIT_LIMIT,
    TIN,
    MRCODE,
    LAST_UPDATED
FROM SALES_DW.BRONZE.CUSTOMER;


CREATE OR REPLACE TABLE SALES_DW.SILVER.INVOICE_HEADER AS
SELECT
    ID                  AS INVOICE_ID,
    INVTYPE,
    INVNO               AS INVOICE_NO,

    TRY_TO_DATE(DATE,'MM/DD/YYYY')
                        AS INVOICE_DATE,

    PONO,
    REMARKS,

    CUSTCODE            AS CUSTOMER_CODE,
    CUSTNAME            AS CUSTOMER_NAME,

    TERMS,
    PREPAREDBY,

    DISCOUNT1,
    DISCOUNT2,

    NETAMT              AS NET_AMOUNT,
    TOTALDISC           AS TOTAL_DISCOUNT,

    PAID,
    BALANCE,

    VAT,
    VATAMT              AS VAT_AMOUNT,

    CANCELLED,
    STATUS,

    LAST_UPDATED

FROM SALES_DW.BRONZE.INVOICE1
WHERE CANCELLED = 0;


CREATE OR REPLACE TABLE SALES_DW.SILVER.INVOICE_DETAIL AS
SELECT
    ID                  AS DETAIL_ID,
    INVNO               AS INVOICE_NO,
    ITEMCODE            AS ITEM_CODE,
    BARCODENO           AS BARCODE,
    ITEMNAME            AS ITEM_NAME,
    PACKING,
    QTY,
    UNITPRICE           AS UNIT_PRICE,
    DISCOUNT,
    AMOUNT,
    TRY_TO_DATE(DATE,'MM/DD/YYYY')
                        AS TRANSACTION_DATE,
    LOTNO,
    TRY_TO_DATE(MFGDATE,'MM/DD/YYYY')
                        AS MANUFACTURE_DATE,
    TRY_TO_DATE(EXPDATE,'MM/DD/YYYY')
                        AS EXPIRY_DATE,
    DEAL,
    LAST_UPDATED
FROM SALES_DW.BRONZE.INVOICE2;

SELECT COUNT(*) FROM SALES_DW.SILVER.CUSTOMER;
SELECT COUNT(*) FROM SALES_DW.SILVER.INVOICE_HEADER;
SELECT COUNT(*) FROM SALES_DW.SILVER.INVOICE_DETAIL;

CREATE OR REPLACE TABLE SALES_DW.SILVER.INVOICE_HEADER AS
SELECT
    ID AS INVOICE_ID,
    INVTYPE,
    INVNO AS INVOICE_NO,
    TRY_TO_DATE(DATE,'MM/DD/YYYY') AS INVOICE_DATE,
    PONO,
    REMARKS,
    CUSTCODE AS CUSTOMER_CODE,
    CUSTNAME AS CUSTOMER_NAME,
    TERMS,
    PREPAREDBY,
    DISCOUNT1,
    DISCOUNT2,
    NETAMT AS NET_AMOUNT,
    TOTALDISC AS TOTAL_DISCOUNT,
    PAID,
    BALANCE,
    VAT,
    VATAMT AS VAT_AMOUNT,
    CANCELLED,
    STATUS,
    LAST_UPDATED
FROM SALES_DW.BRONZE.INVOICE1;

SELECT COUNT(*) FROM SALES_DW.SILVER.INVOICE_HEADER;

CREATE SCHEMA IF NOT EXISTS SALES_DW.GOLD;

CREATE OR REPLACE TABLE SALES_DW.GOLD.DIM_CUSTOMER AS
SELECT
    ROW_NUMBER() OVER (ORDER BY CUSTOMER_CODE) AS CUSTOMER_KEY,
    CUSTOMER_ID,
    CUSTOMER_CODE,
    CUSTOMER_NAME,
    ADDRESS,
    CONTACT_NUMBER,
    CONTACT_PERSON,
    TERMS,
    CREDIT_LIMIT,
    TIN
FROM SALES_DW.SILVER.CUSTOMER;

CREATE OR REPLACE TABLE SALES_DW.GOLD.DIM_ITEM AS
SELECT
    ROW_NUMBER() OVER (ORDER BY ITEM_CODE) AS ITEM_KEY,
    ITEM_CODE,
    ITEM_NAME,
    BARCODE,
    PACKING
FROM (
    SELECT DISTINCT
        ITEM_CODE,
        ITEM_NAME,
        BARCODE,
        PACKING
    FROM SALES_DW.SILVER.INVOICE_DETAIL
);

CREATE OR REPLACE TABLE SALES_DW.GOLD.FACT_SALES AS
SELECT
    h.INVOICE_ID,
    h.INVOICE_NO,
    h.INVOICE_DATE,
    c.CUSTOMER_KEY,
    i.ITEM_KEY,
    d.QTY,
    d.UNIT_PRICE,
    d.DISCOUNT,
    d.AMOUNT,
    h.NET_AMOUNT,
    h.VAT_AMOUNT,
    h.BALANCE,
    h.STATUS
FROM SALES_DW.SILVER.INVOICE_HEADER h
JOIN SALES_DW.SILVER.INVOICE_DETAIL d
    ON h.INVOICE_NO = d.INVOICE_NO
LEFT JOIN SALES_DW.GOLD.DIM_CUSTOMER c
    ON h.CUSTOMER_CODE = c.CUSTOMER_CODE
LEFT JOIN SALES_DW.GOLD.DIM_ITEM i
    ON d.ITEM_CODE = i.ITEM_CODE
WHERE COALESCE(h.CANCELLED,0) = 0;

SELECT COUNT(*) FROM SALES_DW.GOLD.DIM_CUSTOMER;
SELECT COUNT(*) FROM SALES_DW.GOLD.DIM_ITEM;
SELECT COUNT(*) FROM SALES_DW.GOLD.FACT_SALES;


-- reporting views
-- top customer
CREATE OR REPLACE VIEW SALES_DW.GOLD.V_TOP_CUSTOMERS AS
SELECT
    c.CUSTOMER_CODE,
    c.CUSTOMER_NAME,
    SUM(f.AMOUNT) AS TOTAL_PURCHASE,
    COUNT(DISTINCT f.INVOICE_NO) AS TOTAL_INVOICES
FROM SALES_DW.GOLD.FACT_SALES f
JOIN SALES_DW.GOLD.DIM_CUSTOMER c
    ON f.CUSTOMER_KEY = c.CUSTOMER_KEY
GROUP BY c.CUSTOMER_CODE, c.CUSTOMER_NAME
ORDER BY TOTAL_PURCHASE DESC;

--purchases per customer
CREATE OR REPLACE VIEW SALES_DW.GOLD.V_TOTAL_PURCHASE_PER_CUSTOMER AS
SELECT
    c.CUSTOMER_CODE,
    c.CUSTOMER_NAME,
    SUM(f.AMOUNT) AS TOTAL_PURCHASE,
    SUM(f.QTY) AS TOTAL_QTY_PURCHASED,
    COUNT(DISTINCT f.INVOICE_NO) AS INVOICE_COUNT
FROM SALES_DW.GOLD.FACT_SALES f
JOIN SALES_DW.GOLD.DIM_CUSTOMER c
    ON f.CUSTOMER_KEY = c.CUSTOMER_KEY
GROUP BY c.CUSTOMER_CODE, c.CUSTOMER_NAME;

--total item sold
CREATE OR REPLACE VIEW SALES_DW.GOLD.V_TOTAL_ITEM_SOLD AS
SELECT
    i.ITEM_CODE,
    i.ITEM_NAME,
    i.PACKING,
    SUM(f.QTY) AS TOTAL_QTY_SOLD,
    SUM(f.AMOUNT) AS TOTAL_SALES
FROM SALES_DW.GOLD.FACT_SALES f
JOIN SALES_DW.GOLD.DIM_ITEM i
    ON f.ITEM_KEY = i.ITEM_KEY
GROUP BY i.ITEM_CODE, i.ITEM_NAME, i.PACKING
ORDER BY TOTAL_QTY_SOLD DESC;


--monthly sales
CREATE OR REPLACE VIEW SALES_DW.GOLD.V_MONTHLY_SALES AS
SELECT
    YEAR(INVOICE_DATE) AS SALES_YEAR,
    MONTH(INVOICE_DATE) AS SALES_MONTH,
    SUM(AMOUNT) AS TOTAL_SALES,
    COUNT(DISTINCT INVOICE_NO) AS TOTAL_INVOICES,
    SUM(QTY) AS TOTAL_QTY
FROM SALES_DW.GOLD.FACT_SALES
WHERE INVOICE_DATE IS NOT NULL
GROUP BY YEAR(INVOICE_DATE), MONTH(INVOICE_DATE)
ORDER BY SALES_YEAR, SALES_MONTH;

--customer ranking
CREATE OR REPLACE VIEW SALES_DW.GOLD.V_CUSTOMER_RANKING AS
SELECT
    c.CUSTOMER_CODE,
    c.CUSTOMER_NAME,
    SUM(f.AMOUNT) AS TOTAL_PURCHASE,
    RANK() OVER (ORDER BY SUM(f.AMOUNT) DESC) AS CUSTOMER_RANK
FROM SALES_DW.GOLD.FACT_SALES f
JOIN SALES_DW.GOLD.DIM_CUSTOMER c
    ON f.CUSTOMER_KEY = c.CUSTOMER_KEY
GROUP BY c.CUSTOMER_CODE, c.CUSTOMER_NAME;

